# =============================================================================
# VCAI Environment Variables — copy to .env and fill in real values
# DO NOT commit .env to git
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/vcai

# -----------------------------------------------------------------------------
# JWT Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_use_a_long_random_string

# -----------------------------------------------------------------------------
# OpenRouter API (used by LLM and Evaluation modules)
# Get your key at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
USE_OPENROUTER=true
USE_MOCKS=false
PRELOAD_MODELS=true
DEBUG=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
